# API URL for local development. Usa este valor cuando trabajes en tu máquina local.
BITE_API_URL=http://localhost:5118

# API URL para producción / deployment en Render.
# En Render pon esta variable en el panel de Environment Variables o en tu archivo .env si usas build local.
#BITE_API_URL=https://api.corporacionimpactex.com

# Puerto opcional para el servidor SSR si lo ejecutas localmente.
PORT=4000

